# ============================================
# 날씨 기반 코디 추천 시스템 환경변수 설정
# ============================================
#
# 사용법:
# 1. 이 파일을 복사하여 .env.dev로 저장
#    cp .env.dev.example .env.dev
# 2. 각 API 키를 실제 값으로 교체
# 3. python main.py 실행

# --------------------------------------------
# Gemini API (필수)
# --------------------------------------------
# 발급: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# --------------------------------------------
# 기상청 단기예보 API (필수)
# --------------------------------------------
# 발급: https://www.data.go.kr/iim/api/selectAPIAcountView.do
# 서비스명: 기상청_단기예보 ((구)_동네예보) 조회서비스
# 주의: "일반 인증키(Decoding)" 사용 (인코딩 키 사용 시 401 에러 발생)
KMA_API_KEY=your-kma-api-key-here
KMA_API_ENDPOINT=https://apis.data.go.kr/1360000/VilageFcstInfoService_2.0

# --------------------------------------------
# MySQL 설정 (필수)
# --------------------------------------------
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your-mysql-password
MYSQL_DATABASE=clothing_db
